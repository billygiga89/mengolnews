<header class="header">
    <div class="container">
        <div class="brand">
            <img src="/images/Flamengo.png" alt="Flamengo" />
            <h1>MENGOLNEWS</h1>

            <!-- hora e clima — só desktop -->
            <div class="header-info" id="header-info">
                <span id="header-hora"></span>
                <span class="header-info-sep">·</span>
                <span id="header-clima">--°C</span>
            </div>

            <div class="social-icons social-icons-mobile">
                <a href="https://www.instagram.com/blackbillygiga/" target="_blank">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" /></svg>
                </a>
                <a href="https://www.youtube.com/&#64;MengolOficial" target="_blank">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7s-.3-2-1.2-2.8c-1.1-1.2-2.4-1.2-3-1.3C16.6 2.8 12 2.8 12 2.8s-4.6 0-6.8.1c-.6.1-1.9.1-3 1.3C1.3 5 1 7 1 7S.7 9.2.7 11.3v2c0 2.1.3 4.3.3 4.3s.3 2 1.2 2.8c1.1 1.2 2.6 1.1 3.3 1.2C7.5 21.8 12 21.8 12 21.8s4.6 0 6.8-.2c.6-.1 1.9-.1 3-1.3.9-.8 1.2-2.8 1.2-2.8s.3-2.1.3-4.3v-2C23.3 9.2 23 7 23 7zM9.7 15.5V8.4l6.6 3.6-6.6 3.5z" /></svg>
                </a>
                <a href="https://www.tiktok.com/&#64;mengolnews" target="_blank">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 3.4A4.8 4.8 0 0 1 15 0h-3.4v16.5a2.9 2.9 0 0 1-2.9 2.6 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.3 0 .5 0 .8.1V9.9a6.3 6.3 0 0 0-.8-.1 6.3 6.3 0 0 0-6.3 6.3A6.3 6.3 0 0 0 8.7 22.4a6.3 6.3 0 0 0 6.3-6.3V8.2a8.1 8.1 0 0 0 4.7 1.5V6.3a4.8 4.8 0 0 1-3.1-2.9h3.1z" /></svg>
                </a>
            </div>
            <button class="hamburger @(menuAberto ? "open" : "")" @onclick="ToggleMenu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>

        <nav class="nav @(menuAberto ? "nav-open" : "")">
            <NavLink href="/" Match="NavLinkMatch.All" @onclick="FecharMenu">Início</NavLink>
            <NavLink href="/noticias" @onclick="FecharMenu">Notícias</NavLink>
            <NavLink href="/videos" @onclick="FecharMenu">Vídeos</NavLink>
            <NavLink href="/serie-a" @onclick="FecharMenu">Brasileirão</NavLink>
            <NavLink href="/elenco" @onclick="FecharMenu">Elenco</NavLink>
            <NavLink href="/sobre" @onclick="FecharMenu">Sobre</NavLink>
        </nav>

        <!-- Ícones desktop: fora do nav, no container -->
        <div class="social-icons social-icons-desktop">
            <a href="https://www.instagram.com/blackbillygiga/" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" /></svg>
            </a>
            <a href="https://www.youtube.com/&#64;MengolOficial" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7s-.3-2-1.2-2.8c-1.1-1.2-2.4-1.2-3-1.3C16.6 2.8 12 2.8 12 2.8s-4.6 0-6.8.1c-.6.1-1.9.1-3 1.3C1.3 5 1 7 1 7S.7 9.2.7 11.3v2c0 2.1.3 4.3.3 4.3s.3 2 1.2 2.8c1.1 1.2 2.6 1.1 3.3 1.2C7.5 21.8 12 21.8 12 21.8s4.6 0 6.8-.2c.6-.1 1.9-.1 3-1.3.9-.8 1.2-2.8 1.2-2.8s.3-2.1.3-4.3v-2C23.3 9.2 23 7 23 7zM9.7 15.5V8.4l6.6 3.6-6.6 3.5z" /></svg>
            </a>
            <a href="https://www.tiktok.com/&#64;mengolnews" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 3.4A4.8 4.8 0 0 1 15 0h-3.4v16.5a2.9 2.9 0 0 1-2.9 2.6 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.3 0 .5 0 .8.1V9.9a6.3 6.3 0 0 0-.8-.1 6.3 6.3 0 0 0-6.3 6.3A6.3 6.3 0 0 0 8.7 22.4a6.3 6.3 0 0 0 6.3-6.3V8.2a8.1 8.1 0 0 0 4.7 1.5V6.3a4.8 4.8 0 0 1-3.1-2.9h3.1z" /></svg>
            </a>
        </div>
    </div>
</header>
<NewsTicker />
@code {
    bool menuAberto = false;
    void ToggleMenu() => menuAberto = !menuAberto;
    void FecharMenu() => menuAberto = false;
}


