@using MengolNews.Models

<article class="news-card" @onclick="AbrirNoticia">
    <img src="@ImagemFinal"
         alt="@Noticia.Titulo"
         loading="lazy"
         @onerror="OnImageError" />

    <!-- Share buttons — aparecem no hover -->
    <div class="news-share" @onclick:stopPropagation="true">
        <a class="share-btn whatsapp"
           href="@WhatsappUrl"
           target="_blank"
           rel="noopener"
           title="Compartilhar no WhatsApp">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.555 4.126 1.528 5.865L0 24l6.335-1.505A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.805 9.805 0 01-5.032-1.388l-.36-.214-3.762.894.952-3.653-.235-.374A9.798 9.798 0 012.182 12C2.182 6.574 6.574 2.182 12 2.182c5.426 0 9.818 4.392 9.818 9.818 0 5.426-4.392 9.818-9.818 9.818z" />
            </svg>
        </a>
        <a class="share-btn twitter"
           href="@TwitterUrl"
           target="_blank"
           rel="noopener"
           title="Compartilhar no X">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
        </a>
    </div>

    <div class="news-content">
        <span class="news-tag">@Noticia.Fonte</span>
        <h3>@Noticia.Titulo</h3>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public Noticia Noticia { get; set; } = default!;
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private static readonly string[] ImagensFlamengo = new[]
    {
        "/images/flamengo01.jpg",
        "/images/flamengo02.jpg",
        "/images/flamengo03.jpg",
        "/images/flamengo04.jpg",
        "/images/flamengo05.jpg",
        "/images/flamengo06.jpg",
        "/images/flamengo07.jpg",
        "/images/flamengo08.jpg",
        "/images/flamengo09.png",
    };

    private static readonly Random _rng = new();
    private readonly string _imagemFallback =
        ImagensFlamengo[_rng.Next(ImagensFlamengo.Length)];

    private string ImagemFinal =>
        string.IsNullOrWhiteSpace(Noticia.Imagem)
            ? _imagemFallback
            : Noticia.Imagem;

    private string WhatsappUrl =>
        $"https://wa.me/?text={Uri.EscapeDataString(Noticia.Titulo + " " + Noticia.Link)}";

    private string TwitterUrl =>
        $"https://twitter.com/intent/tweet?text={Uri.EscapeDataString(Noticia.Titulo)}&url={Uri.EscapeDataString(Noticia.Link)}";

    private void OnImageError()
    {
        Noticia.Imagem = _imagemFallback;
        StateHasChanged();
    }

    private void AbrirNoticia()
    {
        var url = Uri.EscapeDataString(Noticia.Link);
        NavigationManager.NavigateTo($"/noticia?url={url}");
    }
}





