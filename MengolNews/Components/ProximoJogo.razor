@inject HttpClient Http
@inject IConfiguration Config
@using System.Text.Json
@implements IDisposable

@if (jogo != null)
{
    <div class="proximo-jogo-card">
        <div class="pj-label">⚽ Próximo jogo do Flamengo</div>
        <div class="pj-body">

            <!-- Time da casa -->
            <div class="pj-time home">
                <img class="pj-escudo" src="@jogo.homeCrest" alt="@jogo.home" />
                <span class="pj-nome">@jogo.home</span>
            </div>

            <!-- Centro -->
            <div class="pj-vs">
                <span class="pj-data">@jogo.data.ToString("dd/MM · HH:mm")</span>
                <span class="pj-x">VS</span>
                <span class="pj-comp">@jogo.comp</span>
                @if (countdown != null)
                {
                    <span class="pj-countdown">@countdown</span>
                }
            </div>

            <!-- Time visitante -->
            <div class="pj-time away">
                <img class="pj-escudo" src="@jogo.awayCrest" alt="@jogo.away" />
                <span class="pj-nome">@jogo.away</span>
            </div>

        </div>
    </div>
}

@code {
    record JogoInfo(string home, string away, string homeCrest, string awayCrest, DateTime data, string comp);

    JogoInfo? jogo;
    string? countdown;
    System.Threading.Timer? timer;

    string Api => Config["ApiBaseUrl"] ?? "https://mengolnews-api.onrender.com/";

    private static readonly Dictionary<string, string> NomesFix = new()
    {
        { "Mineiro", "Atlético-MG" },
        { "Paranaense", "Athletico-PR" },
        { "Clube do Remo", "Remo" }
    };

    private string FixNome(string? nome) =>
        nome == null ? "?" : NomesFix.TryGetValue(nome, out var fix) ? fix : nome;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var standings = await Http.GetFromJsonAsync<JsonElement>($"{Api}api/seriea/standings");
            int rodadaAtual = 1;
            if (standings.TryGetProperty("season", out var season) &&
                season.TryGetProperty("currentMatchday", out var cmd))
                rodadaAtual = cmd.GetInt32();

            var agora = DateTime.UtcNow;
            var statusEncerrado = new[] { "FINISHED", "POSTPONED", "CANCELLED", "AWARDED" };

            for (int rodada = rodadaAtual; rodada <= 38; rodada++)
            {
                var res = await Http.GetFromJsonAsync<JsonElement>(
                    $"{Api}api/seriea/matches?matchday={rodada}");
                var partidas = res.GetProperty("matches").EnumerateArray().ToList();

                var proximo = partidas.FirstOrDefault(m =>
                {
                    var status = m.GetProperty("status").GetString();
                    if (statusEncerrado.Contains(status)) return false;
                    var utc = m.GetProperty("utcDate").GetString()!;
                    if (DateTime.Parse(utc) < agora) return false;
                    var home = FixNome(m.GetProperty("homeTeam").GetProperty("shortName").GetString());
                    var away = FixNome(m.GetProperty("awayTeam").GetProperty("shortName").GetString());
                    return home.Contains("Flamengo", StringComparison.OrdinalIgnoreCase)
                        || away.Contains("Flamengo", StringComparison.OrdinalIgnoreCase);
                });

                if (proximo.ValueKind != JsonValueKind.Undefined)
                {
                    var home = FixNome(proximo.GetProperty("homeTeam").GetProperty("shortName").GetString());
                    var away = FixNome(proximo.GetProperty("awayTeam").GetProperty("shortName").GetString());
                    var homeCrest = proximo.GetProperty("homeTeam").TryGetProperty("crest", out var hc) ? hc.GetString() ?? "" : "";
                    var awayCrest = proximo.GetProperty("awayTeam").TryGetProperty("crest", out var ac) ? ac.GetString() ?? "" : "";
                    var utc = proximo.GetProperty("utcDate").GetString()!;
                    var dt = DateTime.Parse(utc).ToLocalTime();
                    var comp = proximo.TryGetProperty("competition", out var c)
                        ? c.GetProperty("name").GetString() ?? "Brasileirão"
                        : "Brasileirão";

                    jogo = new JogoInfo(home, away, homeCrest, awayCrest, dt, comp);
                    IniciarContagem(dt);
                    break;
                }
            }
        }
        catch { }
    }

    private void IniciarContagem(DateTime dataJogo)
    {
        AtualizarCountdown(dataJogo);
        timer = new System.Threading.Timer(_ =>
        {
            AtualizarCountdown(dataJogo);
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void AtualizarCountdown(DateTime dataJogo)
    {
        var diff = dataJogo - DateTime.Now;
        if (diff <= TimeSpan.Zero)
        {
            countdown = "Jogo em andamento!";
            return;
        }
        if (diff.TotalDays >= 1)
            countdown = $"{(int)diff.TotalDays}d {diff.Hours}h {diff.Minutes}m";
        else if (diff.TotalHours >= 1)
            countdown = $"{diff.Hours}h {diff.Minutes}m {diff.Seconds}s";
        else
            countdown = $"{diff.Minutes}m {diff.Seconds}s";
    }

    public void Dispose() => timer?.Dispose();
}