@page "/"

@inject MengolNews.Services.NewsApiService NewsService
@inject NavigationManager Nav
@using NoticiaModel = MengolNews.Models.Noticia

@using MengolNews.Components
@using MengolNews.Models

<PageTitle>MengolNews – Notícias do Flamengo</PageTitle>

@if (isLoading)
{
    <section class="news-list section">
        @for (int i = 0; i < 6; i++)
        {
            <SkeletonNewsCard />
        }
    </section>
}

else if (!isLoading && noticias.Any())
{
    <!-- DESTAQUE -->
    <section class="hero section"
             style="cursor:pointer;"
             @onclick="() => AbrirNoticia(noticias[0])">

        <img src="@ImagemHero" alt="@noticias[0].Titulo" />

        <div class="hero-content">
            <span class="hero-tag">@noticias[0].Fonte</span>
            <h1>@noticias[0].Titulo</h1>
            <time>@noticias[0].Data.ToShortDateString()</time>
        </div>
    </section>


	<!-- OUTRAS -->
	<section class="news-list section">
		@foreach (var noticia in noticias.Skip(1))
		{
			<NewsCard Noticia="noticia" />
		}
	</section>
}
else
{
	<p>Nenhuma notícia encontrada.</p>
}

@code {
    private List<NoticiaModel> noticias = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        await InvokeAsync(StateHasChanged); // 🔥 mostra loading imediatamente

        try
        {
            var dados = await NewsService.GetNoticiasAsync();

            noticias = dados
                .OrderByDescending(n => n.Data)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine("ERRO AO BUSCAR NOTÍCIAS:");
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;

            await InvokeAsync(StateHasChanged);
        }
    }

    private void AbrirNoticia(NoticiaModel noticia)
    {
        var url = Uri.EscapeDataString(noticia.Link);
        Nav.NavigateTo($"/noticia?url={url}");
    }

    private string ImagemHero =>
    noticias.Any() && !string.IsNullOrWhiteSpace(noticias[0].Imagem)
        ? noticias[0].Imagem!
        : "/images/Flamengo.png";
}





    


