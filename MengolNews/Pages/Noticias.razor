@page "/noticias"
@inject MengolNews.Services.NewsApiService NewsService
@inject IJSRuntime JS
@using Microsoft.JSInterop
@using MengolNews.Components
@using MengolNews.Models
@using System.Linq
@implements IDisposable

<PageTitle>Notícias do Flamengo | MengolNews</PageTitle>

<section class="section">
    <h1>Últimas notícias</h1>
    <div class="busca-wrapper">
        <input class="busca-input"
               type="search"
               placeholder="Buscar notícia..."
               @bind="termoBusca"
               @bind:event="oninput" />
    </div>
</section>

@if (isLoading)
{
    <section class="news-list section">
        @for (int i = 0; i < 6; i++)
        {
            <SkeletonNewsCard />
        }
    </section>
}
else if (NoticiasFiltradas.Any())
{
    <section class="news-list section">
        @foreach (var noticia in NoticiasFiltradas)
        {
            <NewsCard Noticia="noticia" />
        }
        @if (PodeCarregarMais && string.IsNullOrWhiteSpace(termoBusca))
        {
            <div class="scroll-sentinel" @ref="sentinel"></div>
        }
    </section>
}
else
{
    <p>Nenhuma notícia encontrada para "<strong>@termoBusca</strong>".</p>
}

@code {
    private List<Noticia?> todas = new();
    private List<Noticia?> noticiasVisiveis = new();
    private string termoBusca = "";
    private int paginaAtual = 0;
    private const int PageSize = 6;
    private bool isLoading = true;
    private bool carregandoMais = false;
    private bool observerIniciado = false;
    private ElementReference sentinel;
    private DotNetObjectReference<Noticias>? objRef;

    private bool PodeCarregarMais =>
        noticiasVisiveis.Count < todas.Count;

    // Quando tem busca ativa, mostra todas filtradas; senão, mostra o scroll infinito normal
    private IEnumerable<Noticia?> NoticiasFiltradas =>
        string.IsNullOrWhiteSpace(termoBusca)
            ? noticiasVisiveis
            : todas.Where(n => n!.Titulo.Contains(termoBusca, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        todas = await NewsService.GetNoticiasAsync();
        todas = todas
            .Where(n => n != null && !string.IsNullOrWhiteSpace(n.Link))
            .GroupBy(n => n!.Link)
            .Select(g => g.First())
            .OrderByDescending(n => n!.Data)
            .ToList();

        CarregarMais();
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!observerIniciado && PodeCarregarMais)
        {
            try
            {
                objRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("infiniteScroll.observe", sentinel, objRef);
                observerIniciado = true;
            }
            catch { }
        }
    }

    private void CarregarMais()
    {
        if (carregandoMais || !PodeCarregarMais) return;
        carregandoMais = true;
        var novas = todas.Skip(paginaAtual * PageSize).Take(PageSize).ToList();
        if (novas.Any())
        {
            noticiasVisiveis.AddRange(novas);
            paginaAtual++;
        }
        carregandoMais = false;
    }

    [JSInvokable]
    public async Task OnScrollChegouNoFim()
    {
        if (carregandoMais || !PodeCarregarMais) return;
        CarregarMais();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}