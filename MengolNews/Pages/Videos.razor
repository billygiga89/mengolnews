@page "/videos"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Vídeos – MengolNews</PageTitle>

<div class="videos-page">
    <div class="videos-header">
        <h1>Vídeos</h1>
    </div>

    @if (carregando)
    {
        <div class="loading">
            <div class="spinner"></div>
            <p>Carregando vídeos...</p>
        </div>
    }
    else if (erro)
    {
        <div class="erro-msg">
            <p>Não foi possível carregar os vídeos. Tente novamente.</p>
            <button class="btn-retry" @onclick="CarregarVideos">Tentar novamente</button>
        </div>
    }
    else if (videos.Count == 0)
    {
        <div class="sem-videos">
            <p>Nenhum vídeo encontrado.</p>
        </div>
    }
    else
    {
        <div class="videos-grid">
            @foreach (var video in videos)
            {
                <div class="video-card" @onclick="() => AbrirPlayer(video)">
                    <div class="thumb-wrap">
                        <img src="@video.Thumbnail" alt="@video.Titulo" loading="lazy" />
                        <div class="play-overlay">
                            <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="30" cy="30" r="30" fill="#B91C1C" />
                                <polygon points="24,18 24,42 46,30" fill="white" />
                            </svg>
                        </div>
                    </div>
                    <div class="video-info">
                        <p class="video-titulo">@video.Titulo</p>
                        <span class="video-data">@FormatarData(video.PublicadoEm)</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (videoAtivo != null)
{
    <div class="modal-overlay" @onclick="FecharPlayer">
        <div class="modal-player" @onclick:stopPropagation="true">
            <button class="modal-close" @onclick="FecharPlayer">✕</button>
            <div class="iframe-wrap">
                <iframe src="@videoAtivo.UrlEmbed"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                </iframe>
            </div>
            <div class="modal-info">
                <p class="modal-titulo">@videoAtivo.Titulo</p>
                <span class="modal-data">@FormatarData(videoAtivo.PublicadoEm)</span>
            </div>
        </div>
    </div>
}

@code {
    private List<VideoDto> videos = new();
    private VideoDto? videoAtivo;
    private bool carregando = true;
    private bool erro = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarVideos();
    }

    private async Task CarregarVideos()
    {
        carregando = true;
        erro = false;

        try
        {
            var resultado = await Http.GetFromJsonAsync<List<VideoDto>>("api/videos");
            videos = resultado ?? new List<VideoDto>();
        }
        catch
        {
            erro = true;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirPlayer(VideoDto video)
    {
        videoAtivo = video;
    }

    private void FecharPlayer()
    {
        videoAtivo = null;
    }

    private string FormatarData(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
            return dt.ToString("dd/MM/yyyy");
        return "";
    }

    public class VideoDto
    {
        public string VideoId { get; set; } = "";
        public string Titulo { get; set; } = "";
        public string Descricao { get; set; } = "";
        public string Thumbnail { get; set; } = "";
        public string PublicadoEm { get; set; } = "";
        public string UrlEmbed { get; set; } = "";
    }
}

<style>
    .videos-page {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1.5rem;
    }

    .videos-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 2rem;
        border-left: 4px solid #B91C1C;
        padding-left: 1rem;
    }

    .videos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .video-card {
        background: #1a1a1a;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid #2a2a2a;
    }

    .video-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(185, 28, 28, 0.3);
    }

    .thumb-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: #111;
    }

    .thumb-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .video-card:hover .thumb-wrap img {
        transform: scale(1.05);
    }

    .play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.3);
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .play-overlay svg {
        width: 56px;
        height: 56px;
        filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
    }

    .video-card:hover .play-overlay {
        opacity: 1;
    }

    .video-info {
        padding: 0.9rem 1rem;
    }

    .video-titulo {
        font-size: 0.95rem;
        font-weight: 600;
        color: #fff;
        line-height: 1.4;
        margin-bottom: 0.4rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .video-data {
        font-size: 0.8rem;
        color: #888;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .modal-player {
        background: #111;
        border-radius: 16px;
        width: 100%;
        max-width: 860px;
        overflow: hidden;
        position: relative;
        border: 1px solid #2a2a2a;
    }

    .modal-close {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(255,255,255,0.1);
        border: none;
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .modal-close:hover {
        background: #B91C1C;
    }

    .iframe-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
    }

    .iframe-wrap iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .modal-info {
        padding: 1rem 1.25rem;
    }

    .modal-titulo {
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 0.25rem;
    }

    .modal-data {
        font-size: 0.8rem;
        color: #888;
    }

    /* Loading */
    .loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 4rem;
        color: #888;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #333;
        border-top-color: #B91C1C;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .erro-msg, .sem-videos {
        text-align: center;
        padding: 4rem;
        color: #888;
    }

    .btn-retry {
        margin-top: 1rem;
        padding: 0.5rem 1.5rem;
        background: #B91C1C;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .btn-retry:hover {
        background: #991b1b;
    }
</style>

