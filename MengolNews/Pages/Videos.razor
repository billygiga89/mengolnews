@page "/videos"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Vídeos – MengolNews</PageTitle>

<div class="videos-page">

    <div class="videos-header">
        <h1>🎬 Vídeos <span class="accent">Mengol</span></h1>
        <p class="videos-subtitle">Conteúdo exclusivo do canal</p>
    </div>

    @if (carregando)
    {
        <div class="videos-grid">
            @for (int i = 0; i < 6; i++)
            {
                <div class="video-card-skeleton">
                    <div class="vsk-thumb"></div>
                    <div class="vsk-info">
                        <div class="vsk-line long"></div>
                        <div class="vsk-line short"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (erro)
    {
        <div class="videos-erro">
            <span>⚠️ Não foi possível carregar os vídeos.</span>
            <button class="btn-retry" @onclick="CarregarVideos">Tentar novamente</button>
        </div>
    }
    else if (videos.Count == 0)
    {
        <div class="videos-erro">
            <span>Nenhum vídeo encontrado.</span>
        </div>
    }
    else
    {
        <div class="videos-grid">
            @foreach (var video in videos)
            {
                <div class="video-card" @onclick="() => AbrirPlayer(video)">
                    <div class="video-thumb">
                        <img src="@video.Thumbnail" alt="@video.Titulo" loading="lazy" />
                        <div class="video-play-btn">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M8 5.14v14l11-7-11-7z" fill="white" />
                            </svg>
                        </div>
                        <div class="video-thumb-overlay"></div>
                    </div>
                    <div class="video-info">
                        <p class="video-titulo">@video.Titulo</p>
                        <span class="video-data">@FormatarData(video.PublicadoEm)</span>
                    </div>
                </div>
            }
        </div>
    }

</div>

@if (videoAtivo != null)
{
    <div class="vmodal-overlay" @onclick="FecharPlayer">
        <div class="vmodal" @onclick:stopPropagation="true">

            <div class="vmodal-header">
                @*<span class="vmodal-tag">▶ Ao vivo no canal</span>*@
                <button class="vmodal-close" @onclick="FecharPlayer">✕</button>
            </div>

            <div class="vmodal-iframe">
                <iframe src="@videoAtivo.UrlEmbed"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                </iframe>
            </div>

            <div class="vmodal-info">
                <p class="vmodal-titulo">@videoAtivo.Titulo</p>
                <span class="vmodal-data">@FormatarData(videoAtivo.PublicadoEm)</span>
            </div>

        </div>
    </div>
}

@code {
    private List<VideoDto> videos = new();
    private VideoDto? videoAtivo;
    private bool carregando = true;
    private bool erro = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarVideos();
    }

    private async Task CarregarVideos()
    {
        carregando = true;
        erro = false;

        try
        {
            var resultado = await Http.GetFromJsonAsync<List<VideoDto>>("api/videos");
            videos = resultado ?? new List<VideoDto>();
        }
        catch
        {
            erro = true;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirPlayer(VideoDto video)
    {
        videoAtivo = video;
    }

    private void FecharPlayer()
    {
        videoAtivo = null;
    }

    private string FormatarData(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
            return dt.ToString("dd/MM/yyyy");
        return "";
    }

    public class VideoDto
    {
        public string VideoId { get; set; } = "";
        public string Titulo { get; set; } = "";
        public string Descricao { get; set; } = "";
        public string Thumbnail { get; set; } = "";
        public string PublicadoEm { get; set; } = "";
        public string UrlEmbed { get; set; } = "";
    }
}


