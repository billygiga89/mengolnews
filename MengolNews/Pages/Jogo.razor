@* Pages/Jogo.razor *@
@page "/jogo"
@using System.Text.Json
@using MengolNews.Components
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@matchTitle — MengolNews</PageTitle>

<div class="jogo-page">

    @if (loading)
    {
        <div class="loading-campo">
            <div class="spinner"></div>
            <p>Carregando o jogo...</p>
        </div>
    }
    else if (erro != null)
    {
        <div class="erro-campo">
            <span>⚠️</span>
            <p>@erro</p>
            <button @onclick="Voltar">← Voltar</button>
        </div>
    }
    else
    {
        <div class="jogo-header-nav">
            <button class="btn-voltar" @onclick="Voltar">← Voltar</button>
            <span class="competicao">@competicao</span>
        </div>

        <CampoVirtual HomeTeam="@homeTeam"
                      AwayTeam="@awayTeam"
                      HomeTeamCrest="@homeCrest"
                      AwayTeamCrest="@awayCrest"
                      HomeScore="@homeScore"
                      AwayScore="@awayScore"
                      Status="@status"
                      Minuto="@minuto"
                      Eventos="@eventos"
                      Stats="@stats"
                      HomeLineup="@homeLineup"
                      AwayLineup="@awayLineup" />

        @if (IsLive)
        {
            <p class="auto-refresh-hint">🔄 Atualizando a cada 30 segundos</p>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery] public int FdId { get; set; }

    private bool loading = true;
    private string? erro;
    private string matchTitle = "Jogo";
    private string competicao = "";
    private string homeTeam = "", awayTeam = "";
    private string? homeCrest, awayCrest;
    private int homeScore, awayScore, minuto;
    private string status = "";

    private List<CampoVirtual.EventoModel>? eventos;
    private List<CampoVirtual.StatModel>? stats;
    private List<CampoVirtual.PlayerModel>? homeLineup;
    private List<CampoVirtual.PlayerModel>? awayLineup;

    private System.Threading.Timer? _timer;

    private bool IsLive => status is "1H" or "2H" or "HT" or "ET" or "P" or "LIVE";

    private const string ApiBase = "https://mengolnews-api.onrender.com";

    protected override async Task OnInitializedAsync() => await LoadMatch();

    async Task Voltar() => await JS.InvokeVoidAsync("history.back");

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || !IsLive) return;

        _timer = new System.Threading.Timer(async _ =>
        {
            try { await LoadMatch(); await InvokeAsync(StateHasChanged); }
            catch { }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadMatch()
    {
        try
        {
            loading = true;

            var response = await Http.GetAsync($"{ApiBase}/api/match/lookup?fdId={FdId}");

            if (!response.IsSuccessStatusCode)
            {
                erro = response.StatusCode == System.Net.HttpStatusCode.NotFound
                    ? "Jogo não encontrado."
                    : "API indisponível. Tente novamente.";
                loading = false;
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            var doc = JsonSerializer.Deserialize<JsonElement>(json);

            // ── Validação básica ──
            if (!doc.TryGetProperty("homeTeam", out var homeTeamEl) ||
                !doc.TryGetProperty("awayTeam", out var awayTeamEl))
            {
                erro = "Resposta da API inválida.";
                loading = false;
                return;
            }

            // ── Times ──
            var homeShort = Str(homeTeamEl, "short");
            homeTeam = string.IsNullOrEmpty(homeShort) ? Str(homeTeamEl, "name") : homeShort;

            var awayShort = Str(awayTeamEl, "short");
            awayTeam = string.IsNullOrEmpty(awayShort) ? Str(awayTeamEl, "name") : awayShort;
            homeCrest = StrNull(homeTeamEl, "logo");
            awayCrest = StrNull(awayTeamEl, "logo");
            matchTitle = $"{homeTeam} x {awayTeam}";

            // ── Competição ──
            competicao = Str(doc, "competition");
            var round = Str(doc, "round");
            if (!string.IsNullOrEmpty(round))
                competicao = string.IsNullOrEmpty(competicao) ? round : $"{competicao} — {round}";

            // ── Status / minuto / placar ──
            status = Str(doc, "status");
            minuto = Int(doc, "minute");
            homeScore = Int(doc, "homeScore");
            awayScore = Int(doc, "awayScore");

            // ── Eventos ──
            eventos = new();
            if (doc.TryGetProperty("events", out var evArr) && evArr.ValueKind == JsonValueKind.Array)
            {
                foreach (var ev in evArr.EnumerateArray())
                {
                    var type = Str(ev, "type");
                    var detail = Str(ev, "detail");
                    var mapped = MapEventType(type, detail);
                    if (mapped == null) continue;

                    var assist = Str(ev, "assist");
                    eventos.Add(new CampoVirtual.EventoModel
                    {
                        Minuto = Int(ev, "minute"),
                        Type = mapped,
                        Player = Str(ev, "player"),
                        Detail = type == "Goal" && !string.IsNullOrEmpty(assist) ? $"Assist: {assist}" : detail,
                        Time = Bool(ev, "isHome") ? "home" : "away",
                        TeamName = Str(ev, "teamName"),
                    });
                }
            }

            // ── Escalação ──
            homeLineup = doc.TryGetProperty("homeLineup", out var hlu) ? ParseLineup(hlu, true) : new();
            awayLineup = doc.TryGetProperty("awayLineup", out var alu) ? ParseLineup(alu, false) : new();

            // ── Stats ──
            stats = new();
            if (doc.TryGetProperty("stats", out var stArr) && stArr.ValueKind == JsonValueKind.Array)
            {
                foreach (var s in stArr.EnumerateArray())
                {
                    stats.Add(new CampoVirtual.StatModel
                    {
                        Name = TranslateStat(Str(s, "name")),
                        HomeValue = Int(s, "homeValue"),
                        AwayValue = Int(s, "awayValue"),
                        Unit = Str(s, "unit"),
                    });
                }
            }

            // Fallback stats mínimas
            if (stats.Count == 0)
            {
                stats = new()
                {
                    new() { Name="Gols",             HomeValue=homeScore, AwayValue=awayScore },
                    new() { Name="Cartões Amarelos",
                        HomeValue=eventos.Count(e=>e.Type=="YELLOW_CARD"&&e.Time=="home"),
                        AwayValue=eventos.Count(e=>e.Type=="YELLOW_CARD"&&e.Time=="away") },
                    new() { Name="Cartões Vermelhos",
                        HomeValue=eventos.Count(e=>e.Type=="RED_CARD"&&e.Time=="home"),
                        AwayValue=eventos.Count(e=>e.Type=="RED_CARD"&&e.Time=="away") },
                    new() { Name="Substituições",
                        HomeValue=eventos.Count(e=>e.Type=="SUBSTITUTION"&&e.Time=="home"),
                        AwayValue=eventos.Count(e=>e.Type=="SUBSTITUTION"&&e.Time=="away") },
                };
            }

            erro = null;
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar jogo: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    // ── Escalação ──
    private List<CampoVirtual.PlayerModel> ParseLineup(JsonElement lu, bool isHome)
    {
        var result = new List<CampoVirtual.PlayerModel>();
        var formation = Str(lu, "formation");
        if (!lu.TryGetProperty("startXI", out var xi)) return result;

        var players = xi.EnumerateArray().ToList();
        bool hasGrid = players.All(p => Str(p, "grid").Contains(':'));

        if (hasGrid)
        {
            foreach (var p in players)
            {
                var grid = Str(p, "grid");
                var row = grid.Split(':')[0];
                int inRow = players.Count(pp => Str(pp, "grid").Split(':')[0] == row);
                var (x, y) = GridToCoords(grid, isHome, inRow);

                result.Add(new CampoVirtual.PlayerModel
                {
                    Name = Str(p, "name"),
                    ShortName = ShortName(Str(p, "name")),
                    Number = Int(p, "number"),
                    Position = MapPosition(Str(p, "position")),
                    X = x,
                    Y = y,
                });
            }
        }
        else
        {
            var pos = GetPositionsByFormation(formation, isHome);
            for (int i = 0; i < players.Count; i++)
            {
                var p = players[i];
                var coords = i < pos.Count ? pos[i] : (isHome ? 200.0 : 600.0, 250.0);
                result.Add(new CampoVirtual.PlayerModel
                {
                    Name = Str(p, "name"),
                    ShortName = ShortName(Str(p, "name")),
                    Number = Int(p, "number"),
                    Position = MapPosition(Str(p, "position")),
                    X = coords.Item1,
                    Y = coords.Item2,
                });
            }
        }

        return result;
    }

    private static (double, double) GridToCoords(string grid, bool isHome, int inRow)
    {
        var p = grid.Split(':');
        if (p.Length != 2 || !int.TryParse(p[0], out var row) || !int.TryParse(p[1], out var col))
            return (isHome ? 200 : 600, 250);

        double xPct = (row - 1.0) / 4.0; // max 5 linhas
        double x = isHome ? 70 + xPct * 350 : 830 - xPct * 350;
        double y = inRow <= 1 ? 250 : 105 + ((col - 1.0) / (inRow - 1.0)) * 290;
        return (Math.Round(x), Math.Round(y));
    }

    // ── Helpers JSON ──
    private static string Str(JsonElement e, string k) => e.TryGetProperty(k, out var v) && v.ValueKind == JsonValueKind.String ? v.GetString() ?? "" : "";
    private static string? StrNull(JsonElement e, string k) => e.TryGetProperty(k, out var v) && v.ValueKind == JsonValueKind.String ? v.GetString() : null;
    private static int Int(JsonElement e, string k) => e.TryGetProperty(k, out var v) && v.ValueKind == JsonValueKind.Number ? v.GetInt32() : 0;
    private static bool Bool(JsonElement e, string k) => e.TryGetProperty(k, out var v) && v.ValueKind == JsonValueKind.True;

    // ── Mapeamentos ──
    private static string? MapEventType(string type, string detail) => type switch
    {
        "Goal" => detail == "Own Goal" ? "OWN_GOAL" : detail == "Penalty" ? "PENALTY" : "GOAL",
        "Card" => detail is "Red Card" or "Second Yellow Card" ? "RED_CARD" : "YELLOW_CARD",
        "subst" => "SUBSTITUTION",
        _ => null,
    };

    private static string TranslateStat(string n) => n switch
    {
        "Ball Possession" => "Posse de Bola",
        "Total Shots" => "Chutes",
        "Shots on Goal" => "Chutes no Gol",
        "Shots off Goal" => "Chutes Fora",
        "Corner Kicks" => "Escanteios",
        "Fouls" => "Faltas",
        "Yellow Cards" => "Cartões Amarelos",
        "Red Cards" => "Cartões Vermelhos",
        "Offsides" => "Impedimentos",
        "Passes accurate" => "Passes Certos",
        "Total passes" => "Total de Passes",
        "Goalkeeper Saves" => "Defesas",
        _ => n,
    };

    private static string ShortName(string full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "";
        var last = full.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? full;
        return last.Length > 10 ? last[..10] : last;
    }

    private static string MapPosition(string p) => p switch
    {
        "G" or "Goalkeeper" => "GOL",
        "D" or "Defender" => "DEF",
        "M" or "Midfielder" => "MEI",
        "F" or "Attacker" => "ATA",
        _ => p.Length > 3 ? p[..3].ToUpper() : p.ToUpper(),
    };

    private static List<(double, double)> GetPositionsByFormation(string formation, bool isHome)
    {
        var linhas = formation.Split('-').Select(s => int.TryParse(s, out var n) ? n : 0).Where(n => n > 0).ToList();
        if (linhas.Count < 2) return GetDefaultPositions(isHome);

        var pos = new List<(double, double)> { (isHome ? 70.0 : 830.0, 250.0) };
        for (int li = 0; li < linhas.Count; li++)
        {
            int qtd = linhas[li];
            double x = isHome ? 130 + ((li + 1.0) / (linhas.Count + 1.0)) * 290
                               : 770 - ((li + 1.0) / (linhas.Count + 1.0)) * 290;
            for (int pi = 0; pi < qtd; pi++)
                pos.Add((Math.Round(x), Math.Round(105 + ((pi + 1.0) / (qtd + 1.0)) * 290)));
        }
        return pos;
    }

    private static List<(double, double)> GetDefaultPositions(bool isHome) => isHome
        ? new() { (70, 250), (155, 145), (155, 215), (155, 285), (155, 360), (255, 185), (255, 250), (255, 325), (355, 155), (355, 250), (355, 350) }
        : new() { (830, 250), (745, 145), (745, 215), (745, 285), (745, 360), (645, 185), (645, 250), (645, 325), (545, 155), (545, 250), (545, 350) };

    public void Dispose() => _timer?.Dispose();
}
